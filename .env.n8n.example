# ============================================================
# VARIAVEIS DE AMBIENTE PARA O N8N + REDIS
# Copie para .env.n8n e preencha com valores reais.
# NUNCA commite o arquivo .env.n8n no repositório.
# ============================================================

# --- Credenciais do painel do n8n ---
# Gerar senha forte: openssl rand -base64 32
N8N_ADMIN_USER=aevum_admin
N8N_ADMIN_PASSWORD=TROQUE_POR_SENHA_FORTE

# Chave de criptografia para credenciais salvas no n8n
# Gerar: openssl rand -base64 32
N8N_ENCRYPTION_KEY=TROQUE_POR_CHAVE_ALEATORIA

# --- URL pública do n8n (usada nos webhooks) ---
# Deve ser HTTPS em produção (ex: https://n8n.seudominio.com)
N8N_PROTOCOL=https
N8N_WEBHOOK_BASE_URL=https://n8n.seudominio.com

# --- Banco de dados exclusivo do n8n ---
# Use um banco SEPARADO do banco do sistema Aevum
N8N_DB_HOST=seu-host-neon.aws.neon.tech
N8N_DB_PORT=5432
N8N_DB_NAME=n8n_db
N8N_DB_USER=n8n_user
N8N_DB_PASSWORD=TROQUE_POR_SENHA_FORTE
N8N_DB_SSL=true

# --- Redis ---
# Gerar senha: openssl rand -base64 24
REDIS_PASSWORD=TROQUE_POR_SENHA_REDIS

# --- Fuso horário ---
TZ=America/Sao_Paulo

# ============================================================
# VARIAVEIS DOS WORKFLOWS N8N
# Configure estas como variáveis de ambiente no painel do n8n:
# Settings > Variables
# ============================================================

# Backend Aevum
API_BASE_URL=https://seu-backend.vercel.app/api

# API Key da empresa (gerada em /api/admin/integrations)
EMPRESA_API_KEY=CLOUDDAGENDA_<ID>_<HASH>
EMPRESA_ID=<numero_id_empresa>
EMPRESA_NOME=Nome da Empresa

# Secret compartilhado para validar webhooks do backend
# Deve ser o mesmo valor de WEBHOOK_SECRET no backend
WEBHOOK_SECRET=TROQUE_POR_HEX_64_CHARS

# --- Evolution API (WhatsApp) ---
EVOLUTION_API_URL=https://evolution.seudominio.com
EVOLUTION_API_KEY=CHAVE_EVOLUTION
EVOLUTION_INSTANCE_NAME=nome-da-instancia

# --- IA ---
ANTHROPIC_API_KEY=sk-ant-...
# ou
OPENAI_API_KEY=sk-...

# --- Redis URL (para os workflows usarem diretamente) ---
REDIS_URL=redis://:SENHA_REDIS@redis:6379
