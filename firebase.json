{
  "hosting": [
    {
      "target": "empresa",
      "public": "frontend",
      "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
      "cleanUrls": false,
      "rewrites": [
        { "source": "/app/**", "destination": "/app/agendamentos.html" }
      ]
    },
    {
      "target": "admin",
      "public": "frontend/admin",
      "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
      "cleanUrls": true,
      "rewrites": [
        { "source": "/dashboard", "destination": "/dashboard.html" },
        { "source": "/users", "destination": "/users.html" },
        { "source": "/integrations", "destination": "/integrations.html" },
        { "source": "/saas", "destination": "/saas.html" },
        { "source": "**", "destination": "/dashboard.html" }
      ]
    }
  ],
  "functions": [
    {
      "source": "backend",
      "codebase": "default",
      "ignore": [
        "node_modules",
        ".git",
        "database.sqlite",
        "*.local"
      ]
    }
  ]
}
