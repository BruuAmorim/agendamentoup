{
  "hosting": {
    "public": "frontend",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "rewrites": [
      {
        "source": "/api/**",
        "function": {
          "functionId": "api",
          "region": "southamerica-east1"
        }
      },
      { "source": "/admin/dashboard", "destination": "/admin/dashboard.html" },
      { "source": "/admin/users", "destination": "/admin/users.html" },
      { "source": "/admin/integrations", "destination": "/admin/integrations.html" }
    ]
  },
  "functions": [
    {
      "source": "backend",
      "codebase": "default",
      "ignore": [
        "node_modules",
        ".git",
        "database.sqlite",
        "*.local"
      ]
    }
  ]
}
