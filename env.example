# Backend - variáveis para rodar localmente e no Vercel
# No Vercel: configurar em Project > Settings > Environment Variables
# API em produção: https://cloudd-agenda-backend.vercel.app/api

PORT=3000
NODE_ENV=production

# Obrigatório em produção (Supabase, Neon, etc.)
# Para rodar localmente SEM Postgres: use `npm run start:local` (ignora DATABASE_URL e usa SQLite).
# Ou comente esta linha e use `npm start` — o backend usará SQLite (database.sqlite).
DATABASE_URL=postgres://usuario:senha@host:porta/banco?sslmode=require

# Opcional: forçar SQLite local mesmo com DATABASE_URL definido (npm run start:local faz isso automaticamente)
# USE_SQLITE_LOCAL=true

# Segurança - defina um segredo forte em produção
JWT_SECRET=seu-jwt-secret-muito-seguro

# Opcional: URL do frontend para CORS (já permite *.vercel.app)
# FRONTEND_URL=https://seu-app.vercel.app
