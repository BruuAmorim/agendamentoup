{
  "version": 2,
  "name": "cloudd-agenda-backend",
  "installCommand": "npm install",
  "buildCommand": "npm run build",
  "builds": [
    { "src": "api/index.js", "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api" },
    { "src": "/api", "dest": "/api" },
    { "src": "/", "dest": "/api" }
  ]
}
